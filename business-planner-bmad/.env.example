ANTHROPIC_API_KEY=                              # Anthropic API key for the Claude Agent SDK orchestrator (Story 1.7+)
TAVILY_API_KEY=                                 # Tavily web-research API key (Epic 2 — Story 2.3)
PINECONE_API_KEY=                               # Pinecone vector DB API key (Epic 2 — Story 2.1)
PINECONE_INDEX=business-planner-intelligence    # Pinecone index name; one index, namespaced per project
VOYAGE_API_KEY=                                 # Voyage embeddings API key (Epic 2 — Story 2.1)
DATABASE_URL=postgres://bp:bp@localhost:5432/businessplanner  # Postgres URL — Phase 2 placeholder, unused in Phase 1
DATA_ROOT=./data                                # Local filesystem root for sessions, costs, logs (architecture §Data layout)
PORT=3000                                       # Fastify server port (binds 127.0.0.1 only)
WEB_PORT=5173                                   # Vite dev server port
NODE_ENV=development                            # Node environment: development | production | test
