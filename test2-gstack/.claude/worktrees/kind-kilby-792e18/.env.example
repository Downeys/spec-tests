# oneBrain Composer — environment template.
# Copy to .env and fill in. NEVER commit .env (see .gitignore).

# Per-venture identity. bin/new-venture writes a unique value here.
VENTURE_NAME=local-radio

# Postgres connection. docker-compose maps host port; bin/new-venture picks a free port per venture.
DATABASE_URL=postgres://onebrain:onebrain@localhost:5432/onebrain

# Where the wiki compiler writes Obsidian markdown (Phase 3+).
# Defaults to ./wiki at repo root.
WIKI_OUTPUT_DIR=./wiki

# Anthropic — used by wiki-compiler synthesis (Claude Opus by default; see Open Question 1).
ANTHROPIC_API_KEY=

# Tavily — used by tavily_search and fetch_and_archive (Phase 1+).
TAVILY_API_KEY=

# Daily budget cap (USD). When exceeded, all paid tools return PERMANENT 'budget cap reached'.
# Per CMT4. Set to 0 to disable the cap.
CC_DAILY_USD_CAP=10.00

# Compile timeout (seconds). compile_wiki AbortController fires past this. Per A2.
COMPILE_MAX_SECONDS=90

# Critical-posture sentinel. Returned by verify_critical_posture; agent checks on first turn.
# Per A5. Change per-venture if you want venture-specific posture.
CRITICAL_POSTURE_SENTINEL=onebrain-critical-posture-v1
