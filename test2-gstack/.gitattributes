# Enforce LF on platform-sensitive text files (per T3 / CMT5 — Windows checklist).
# Without this, .env CRLF can break dotenv loaders, and shell scripts with CRLF
# fail under bash on Windows / Git Bash / WSL2.

* text=auto eol=lf

# Explicitly LF for files where line endings matter.
*.sh         text eol=lf
*.bash       text eol=lf
.env*        text eol=lf
Dockerfile*  text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf

# Markdown / TS / JSON — LF as well; consistency keeps diffs clean across machines.
*.md         text eol=lf
*.ts         text eol=lf
*.tsx        text eol=lf
*.json       text eol=lf

# Binary — never normalize.
*.png        binary
*.jpg        binary
*.pdf        binary
*.gz         binary
