{
  "name": "business-strategy-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "bsp": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.node.json",
    "build:web": "vite build",
    "tsc:web": "tsc --noEmit -p tsconfig.web.json",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --project integration",
    "test:voyage": "RUN_VOYAGE_TESTS=1 vitest run tests/integration/voyage-live.test.ts",
    "test:tavily": "RUN_TAVILY_TESTS=1 vitest run tests/agents/tavily.spec.ts",
    "test:agent": "RUN_AGENT_TESTS=1 vitest run --project agents",
    "test:full": "RUN_VOYAGE_TESTS=1 RUN_TAVILY_TESTS=1 RUN_AGENT_TESTS=1 vitest run",
    "migrate": "node-pg-migrate up --migration-file-language sql",
    "migrate:down": "node-pg-migrate down --migration-file-language sql",
    "db:push": "echo 'FORBIDDEN — schema is owned by node-pg-migrate. Use: npm run migrate' && exit 1",
    "drizzle:pull": "drizzle-kit pull",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.{ts,tsx,md,json,yaml}\"",
    "bsp": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@anthropic-ai/claude-agent-sdk": "0.2.119",
    "@anthropic-ai/sdk": "^0.90.0",
    "@assistant-ui/react": "^0.12.26",
    "@assistant-ui/react-ai-sdk": "^1.3.20",
    "@hono/node-server": "^2.0.0",
    "@tavily/core": "^0.7.2",
    "ai": "^6.0.168",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.15",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "ulid": "^3.0.2",
    "unified": "^11.0.5",
    "voyageai": "^0.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@arizeai/openinference-instrumentation-anthropic": "^0.1.10",
    "@assistant-ui/react-markdown": "^0.12.11",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/ui": "^4.1.5",
    "assistant-ui": "^0.0.90",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^29.0.2",
    "lucide-react": "^1.11.0",
    "prettier": "^3.8.3",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.6",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  }
}
