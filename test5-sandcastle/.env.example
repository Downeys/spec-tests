# OpenBrain Postgres connection URLs.
# Two separate roles enforce the append-only invariant at the GRANT layer
# (see docs/adr/0024-two-role-postgres-model.md). The admin URL drives
# migrations and DDL; the app URL is what the runtime adapter holds and
# physically cannot UPDATE/DELETE on append-only tables.
OPENBRAIN_ADMIN_URL=postgres://openbrain_admin:openbrain_admin@127.0.0.1:5432/openbrain
OPENBRAIN_APP_URL=postgres://openbrain_app:openbrain_app@127.0.0.1:5432/openbrain

# Voyage embeddings API key. Not used in slice 1 (no embedding population yet
# — that lands with the sources table in slice 2). Set when the Voyage
# adapter ships per docs/adr/0022-voyage-for-embeddings.md.
# VOYAGE_API_KEY=
