{
  "name": "test5-sandcastle",
  "private": true,
  "type": "module",
  "scripts": {
    "drain": "tsx .sandcastle/main.ts",
    "ship": "tsx .sandcastle/ship.ts",
    "sweep": "tsx .sandcastle/sweep.ts",
    "typecheck": "tsc --noEmit && tsc -p apps/ui/tsconfig.json --noEmit",
    "lint": "eslint --ext .ts,.tsx packages/ apps/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage && vitest run --project domain --coverage --coverage.include='packages/domain/**/*.ts' --coverage.exclude='**/*.test.ts' --coverage.exclude='**/index.ts' --coverage.thresholds.lines=90 --coverage.thresholds.branches=90",
    "format": "prettier --write 'packages/**/*.ts' 'apps/**/*.ts' '*.json' '*.yaml'",
    "format:check": "prettier --check 'packages/**/*.ts' 'apps/**/*.ts' '*.json' '*.yaml'",
    "bp-agent": "tsx apps/agent/main.ts",
    "bp-api": "tsx apps/api/main.ts",
    "bp-ui": "pnpm --filter @bp-agent/ui dev",
    "db:up": "docker compose up -d openbrain",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d openbrain",
    "db:migrate": "pnpm --filter @bp-agent/openbrain migrate",
    "db:migrate:status": "pnpm --filter @bp-agent/openbrain migrate:status",
    "db:psql": "docker compose exec openbrain psql -U openbrain_admin -d openbrain",
    "prepare": "husky"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "0.5.7",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^4.0.0",
    "eslint-plugin-local": "workspace:*",
    "execa": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
