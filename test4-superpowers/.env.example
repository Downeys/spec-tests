# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=business_plan
POSTGRES_DB_TEST=business_plan_test
POSTGRES_PORT=5432

# Connection strings (computed from above; convenient for tools)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/business_plan
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/business_plan_test

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@local
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# Vault
VAULT_PATH=./vault

# Anthropic (PRD 2 — agent shell)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_PRIMARY=claude-opus-4-7
ANTHROPIC_MODEL_COMPACTOR=claude-haiku-4-5-20251001

# Voyage AI (PRD 2 — embeddings)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# Backend service
PORT=8787
FRONTEND_ORIGIN=http://localhost:5173

# Token budgeting (PRD 2)
TOKEN_BUDGET=400000
TOKEN_SOFT_WARN=0.75
TOKEN_HARD_WARN=0.90
